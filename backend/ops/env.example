NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://postgres:postgres@localhost:5433/mcu_backend

MQTT_URL=mqtt://localhost:1883
# Required when using the bundled Node MQTT broker in secure mode.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
# Set true only on isolated local dev machines.
MQTT_ALLOW_ANONYMOUS=false
MQTT_AUTO_PROVISION=false
MQTT_TOPIC_TENANT_ALIASES=tenant-01=tnr13
MQTT_TOPIC_VESSEL_ALIASES=vessel-01=vsl-001
MQTT_TOPIC_EDGE_ALIASES=remote_01=edge-001
WORK_SOURCE_ADDRESSES=192.168.88.10,192.168.88.11
ENTERTAINMENT_SOURCE_ADDRESSES=192.168.88.20,192.168.88.21
VSAT_GATEWAY=10.10.10.1
STARLINK_GATEWAY=100.64.0.1

BASIC_AUTH_ENABLED=true
BASIC_AUTH_USERNAME=demo
BASIC_AUTH_PASSWORD=
BASIC_AUTH_ROLE=admin
AUTH_TOKEN_SECRET=replace_me
AUTH_TOKEN_TTL_SECONDS=3600
TRUST_PROXY_HEADERS=true

MCU_REGISTER_ENABLED=false
MCU_REGISTER_TOKEN=

NGROK_AUTHTOKEN=
NGROK_WEB_ADDR=127.0.0.1:4040
# Optional: set a short reserved ngrok domain for the API/dashboard.
# Example: dashboard.ngrok.app or your own custom domain.
NGROK_API_DOMAIN=
NGROK_ENABLE_MQTT_TUNNEL=false
NGROK_DEVICE_HINT=

# Legacy placeholders kept for future auth expansion.
JWT_SECRET=replace_me
JWT_EXPIRES_IN=3600

LOG_LEVEL=info
