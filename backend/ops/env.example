NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://postgres:postgres@localhost:5433/mcu_backend

MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
NGROK_AUTHTOKEN=
NGROK_WEB_ADDR=127.0.0.1:4040
# Optional: set a short reserved ngrok domain for the API/dashboard.
# Example: dashboard.ngrok.app or your own custom domain.
NGROK_API_DOMAIN=

# Optional: Nginx reverse proxy settings for direct IP/domain access.
NGINX_LISTEN_PORT=80
NGINX_SERVER_NAME=_
NGINX_UPSTREAM_HOST=127.0.0.1
NGINX_UPSTREAM_PORT=3000

JWT_SECRET=replace_me
JWT_EXPIRES_IN=3600

LOG_LEVEL=info
